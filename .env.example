# Public site URL (metadata, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://zadex.se

# Required: mailbox password for info@zadex.se (one.com SMTP)
EMAIL_PASS=your-email-password

# Optional overrides (defaults match one.com + info@zadex.se)
SMTP_HOST=send.one.com
SMTP_PORT=465
SMTP_USER=info@zadex.se
SMTP_SECURE=true

# From / to addresses
SMTP_FROM="zadex <info@zadex.se>"
CONTACT_TO=info@zadex.se
